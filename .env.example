# Copy this file to .env and adjust as needed. .env is gitignored.

# --- Postgres (docker-compose + src/pdp/config.py) ---
POSTGRES_USER=pdp
POSTGRES_PASSWORD=pdp
POSTGRES_DB=pdp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full DSN used by psycopg; must stay consistent with the values above.
DATABASE_URL=postgresql://pdp:pdp@localhost:5432/pdp  # pragma: allowlist secret
